# Required Discord configuration
DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me

# Optional: comma-separated guild ids for instant slash command registration while testing.
# Leave empty to register global commands.
DISCORD_GUILD_IDS=

# Internal service ports
BOT_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_BOT_WS_URL=ws://localhost:4000/ws
BOT_API_URL=http://bot:4000

# Dashboard protection. Change before exposing the panel publicly.
DASHBOARD_ADMIN_TOKEN=change_me

# Lavalink
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=change_lavalink_password
LAVALINK_SECURE=false
YOUTUBE_OAUTH_ENABLED=false

# Optional metadata providers. Missing keys gracefully fall back to YouTube/text search.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YANDEX_MUSIC_TOKEN=
VK_ACCESS_TOKEN=

# Runtime tuning for small VPS instances
NODE_ENV=production
JAVA_OPTS=-Xms128m -Xmx512m
